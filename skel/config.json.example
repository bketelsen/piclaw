{
  "sessionAutoRotate": true,
  "sessionMaxSizeMb": 32,
  "tools": {
    "additionalDefaultTools": [
      "search_workspace"
    ],
    "workspaceSearchRoots": [
      "notes",
      ".pi/skills",
      "docs",
      "workitems"
    ]
  },
  "telegram": {
    "botTokenEnv": "PICLAW_TELEGRAM_BOT_TOKEN",
    "allowedUsersEnv": "PICLAW_TELEGRAM_ALLOWED_USERS"
  }
}
